# Deterministic AI Debate System — Environment Configuration
# Copy this file to .env and fill in your actual values.

# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key for LLM calls (obtain at console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Semantic Drift Evaluation ─────────────────────────────────────────────────
RECENCY_DECAY_LAMBDA=0.3
V1_DISTANCE_THRESHOLD=0.4
CENTROID_ALIGNMENT_THRESHOLD=0.7

# ── Debate Run Parameters ─────────────────────────────────────────────────────
MAX_ROUNDS=10
BENCHMARK_RUNS=5
LEDGER_WINDOW=3
MAX_WORKERS=4

# ── Model Configuration ───────────────────────────────────────────────────────
LLM_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Output ────────────────────────────────────────────────────────────────────
ASSETS_DIR=assets/
